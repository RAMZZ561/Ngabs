-- Aimbot & ESP Render Loop
RunService.RenderStepped:Connect(function()
    -- Aimbot FOV Circle
    if DrawingEnabled and FOVCircle then
        FOVCircle.Visible = Config.Aimbot.Enabled
        FOVCircle.Radius = Config.Aimbot.FOV
        FOVCircle.Position = Vector2.new(Mouse.X, Mouse.Y)
    end

    -- ESP Logic
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = player.Character.HumanoidRootPart
            local head = player.Character:FindFirstChild("Head")
            local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
            
            if not humanoid or humanoid.Health <= 0 then
                -- Clean up dead ESP
                if ESPObjects[player] then
                    for _, obj in pairs(ESPObjects[player]) do if obj.Destroy then obj:Destroy() end end
                    ESPObjects[player] = nil
                end
                continue
            end

            if Config.ESP.Enabled and DrawingEnabled then
                if not ESPObjects[player] then ESPObjects[player] = {} end
                local objs = ESPObjects[player]
                
                local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
                
                if onScreen then
                    -- Box
                    if Config.ESP.Box then
                        if not objs.Box then
                            objs.Box = DrawingAPI.new("Square")
                            objs.Box.Thickness = 1
                            objs.Box.Filled = false
                        end
                        local size = hrp.Size
                        local topLeft, _ = Camera:WorldToViewportPoint(hrp.Position + Vector3.new(-size.X, size.Y, 0))
                        local bottomRight, _ = Camera:WorldToViewportPoint(hrp.Position + Vector3.new(size.X, -size.Y, 0))
                        objs.Box.Size = Vector2.new(bottomRight.X - topLeft.X, bottomRight.Y - topLeft.Y)
                        objs.Box.Position = Vector2.new(topLeft.X, topLeft.Y)
                        objs.Box.Color = Config.ESP.Color
                        objs.Box.Visible = true
                    elseif objs.Box then objs.Box.Visible = false end

                    -- Tracers
                    if Config.ESP.Tracers then
                        if not objs.Line then objs.Line = DrawingAPI.new("Line") objs.Line.Thickness = 1 end
                        objs.Line.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                        objs.Line.To = Vector2.new(pos.X, pos.Y)
                        objs.Line.Color = Config.ESP.Color
                        objs.Line.Visible = true
                    elseif objs.Line then objs.Line.Visible = false end
                    
                    -- Name & Health
                    if Config.ESP.Name or Config.ESP.Health then
                        if not objs.Text then objs.Text = DrawingAPI.new("Text") objs.Text.Size = 12 objs.Text.Center = true objs.Text.Outline = true end
                        local str = ""
                        if Config.ESP.Name then str = str .. player.Name .. "\n" end
                        if Config.ESP.Health then str = str .. math.floor(humanoid.Health) .. " HP" end
                        objs.Text.Text = str
                        objs.Text.Position = Vector2.new(pos.X, pos.Y - 40)
                        objs.Text.Color = Config.ESP.Color
                        objs.Text.Visible = true
                    elseif objs.Text then objs.Text.Visible = false end
                else
                    if objs.Box then objs.Box.Visible = false end
                    if objs.Line then objs.Line.Visible = false end
                    if objs.Text then objs.Text.Visible = false end
                end
            else
                if ESPObjects[player] then
                    for _, obj in pairs(ESPObjects[player]) do if obj.Destroy then obj:Destroy() end end
                    ESPObjects[player] = nil
                end
            end
            
            
                
             -- Aimbot Target Lock
            if Config.Aimbot.Enabled and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
                local target = nil
                local minDist = Config.Aimbot.FOV
                
                for _, other in pairs(Players:GetPlayers()) do
                    if other ~= LocalPlayer and other.Character and other.Character:FindFirstChild(Config.Aimbot.TargetPart) then
                        local hum = other.Character:FindFirstChildOfClass("Humanoid")
                        if hum and hum.Health > 0 then
                            local part = other.Character[Config.Aimbot.TargetPart]
                            local screenPos, vis = Camera:WorldToViewportPoint(part.Position)
                            if vis then
                                local dist = (Vector2.new(screenPos.X, screenPos.Y) - Vector2.new(Mouse.X, Mouse.Y)).Magnitude
                                if dist < minDist then
                                    minDist = dist
                                    target = part
                                end
                            end
                        end
                    end
                end
                
                if target then
                    if Config.Aimbot.Mode == "Normal" then
                        Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, target.Position)
                    elseif Config.Aimbot.Mode == "Legit" then
                        local goalCF = CFrame.lookAt(Camera.CFrame.Position, target.Position)
                        Camera.CFrame = Camera.CFrame:Lerp(goalCF, math.clamp(Config.Aimbot.Smoothing, 0.1, 0.9))
                    end
                end
            end
        end
    end
end)

