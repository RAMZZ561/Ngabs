-- MAIN EXECUTION LOOP
local sessionTime = 0
RunService.RenderStepped:Connect(function(dt)
    sessionTime = sessionTime + dt
    local h = math.floor(sessionTime / 3600)
    local m = math.floor((sessionTime % 3600) / 60)
    local s = math.floor(sessionTime % 60)
    
    for _, lbl in ipairs(Footer:GetDescendants()) do
        if lbl:IsA("TextLabel") and lbl.Text:find("Session") then lbl.Text = string.format("🕐  Session: %02d:%02d:%02d", h, m, s) end
        if lbl:IsA("TextLabel") and lbl.Text:find("Players") then lbl.Text = "👥  Players: " .. #Players:GetPlayers() end
    end
    
    -- MOVEMENT & FLY
    if LocalPlayer.Character then
        local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        
        if hum then
            hum.WalkSpeed = Config.WalkSpeed
            hum.JumpPower = Config.JumpPower
        end
        
        if Config.Fly.Enabled and hrp then
            hrp.Velocity = Vector3.new(0, 0, 0)
            local moveDir = Vector3.new(0, 0, 0)
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - Camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + Camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDir = moveDir + Vector3.new(0, 1, 0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then moveDir = moveDir - Vector3.new(0, 1, 0) end
            if moveDir.Magnitude > 0 then hrp.CFrame = hrp.CFrame + moveDir.Unit * Config.Fly.Speed * 0.1 end
        end
        
        if Config.Noclip then
            for _, part in ipairs(LocalPlayer.Character:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end
    end
    
    -- INFINITE JUMP
    if Config.InfiniteJump and UserInputService:IsKeyDown(Enum.KeyCode.Space) then
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
            LocalPlayer.Character:FindFirstChildOfClass("Humanoid"):ChangeState(Enum.HumanoidStateType.Jumping)
        end
    end
    
    -- ANTI AFK
    if Config.AntiAFK and math.random(1, 500) == 1 then
        local v = Instance.new("VirtualUser"); v:CaptureController(); v:ClickButton2(Vector2.new())
    end

    -- AIMBOT & ESP LOGIC
    if DrawingEnabled and FOVCircle then
        FOVCircle.Visible = Config.Aimbot.Enabled
        FOVCircle.Position = Vector2.new(Mouse.X, Mouse.Y)
    end

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = player.Character.HumanoidRootPart
            local head = player.Character:FindFirstChild("Head")
            local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
            
            if not humanoid or humanoid.Health <= 0 then
                if ESPObjects[player] then
                    for _, obj in pairs(ESPObjects[player]) do if obj.Remove then obj:Remove() end end
                    ESPObjects[player] = nil
                end
                continue
            end

            if Config.ESP.Enabled and DrawingEnabled then
                if not ESPObjects[player] then ESPObjects[player] = {} end
                local objs = ESPObjects[player]
                local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
                
                if onScreen then
                    if Config.ESP.Box then
                        if not objs.Box then objs.Box = DrawingAPI.new("Square"); objs.Box.Thickness = 1; objs.Box.Filled = false end
                        local size = hrp.Size
                        local topLeft, _ = Camera:WorldToViewportPoint(hrp.Position + Vector3.new(-size.X, size.Y, 0))
                        local bottomRight, _ = Camera:WorldToViewportPoint(hrp.Position + Vector3.new(size.X, -size.Y, 0))
                        objs.Box.Size = Vector2.new(bottomRight.X - topLeft.X, bottomRight.Y - topLeft.Y)
                        objs.Box.Position = Vector2.new(topLeft.X, topLeft.Y)
                        objs.Box.Color = C.Accent; objs.Box.Visible = true
                    elseif objs.Box then objs.Box.Visible = false end

                    if Config.ESP.Tracer then
                        if not objs.Line then objs.Line = DrawingAPI.new("Line"); objs.Line.Thickness = 1 end
                        objs.Line.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                        objs.Line.To = Vector2.new(pos.X, pos.Y)
                        objs.Line.Color = C.Accent; objs.Line.Visible = true
                    elseif objs.Line then objs.Line.Visible = false end
                    
                    if Config.ESP.Name or Config.ESP.Health or Config.ESP.Distance then
                        if not objs.Text then objs.Text = DrawingAPI.new("Text"); objs.Text.Size = 13; objs.Text.Center = true; objs.Text.Outline = true end
                        local str = ""
                        if Config.ESP.Name then str = str .. player.Name .. "\n" end
                        if Config.ESP.Health then str = str .. math.floor(humanoid.Health) .. " HP\n" end
                        if Config.ESP.Distance then str = str .. math.floor((hrp.Position - Camera.CFrame.Position).Magnitude) .. " Studs" end
                        objs.Text.Text = str; objs.Text.Position = Vector2.new(pos.X, pos.Y - 50)
                        objs.Text.Color = C.AccentLight; objs.Text.Visible = true
                    elseif objs.Text then objs.Text.Visible = false end
                else
                    if objs.Box then objs.Box.Visible = false end
                    if objs.Line then objs.Line.Visible = false end
                    if objs.Text then objs.Text.Visible = false end
                end
            else
                if ESPObjects[player] then
                    for _, obj in pairs(ESPObjects[player]) do if obj.Remove then obj:Remove() end end
                    ESPObjects[player] = nil
                end
            end
            
            -- AIMBOT TARGET LOCK
            if Config.Aimbot.Enabled and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
                local target = nil; local minDist = Config.Aimbot.FOV
                for _, other in pairs(Players:GetPlayers()) do
                    if other ~= LocalPlayer and other.Character and other.Character:FindFirstChild("Head") then
                        local otherHum = other.Character:FindFirstChildOfClass("Humanoid")
                        if otherHum and otherHum.Health > 0 then
                            local part = other.Character.Head
                            local screenPos, vis = Camera:WorldToViewportPoint(part.Position)
                            if vis then
                                local dist = (Vector2.new(screenPos.X, screenPos.Y) - Vector2.new(Mouse.X, Mouse.Y)).Magnitude
                                if dist < minDist then minDist = dist; target = part end
                            end
                        end
                    end
                end
                if target then
                    local goalCF = CFrame.lookAt(Camera.CFrame.Position, target.Position)
                    Camera.CFrame = Camera.CFrame:Lerp(goalCF, math.clamp(Config.Aimbot.Smoothness, 0.1, 0.9))
                end
            end
        end
    end
end)

