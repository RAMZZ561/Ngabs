local function CreateToggleCard(title, desc, icon, parent, yPos, default, callback)
    local card = CreateCard(title, desc, icon, parent, yPos)
    
    local toggleBg = Create("Frame", {
        Size = UDim2.new(0, 44, 0, 22),
        Position = UDim2.new(1, -56, 0.5, -11),
        BackgroundColor3 = default and C.Accent or C.Sidebar,
        BorderSizePixel = 0
    }, card)
    Create("UICorner", {CornerRadius = UDim.new(1, 0)}, toggleBg)
    
    local toggleCircle = Create("Frame", {
        Size = UDim2.new(0, 18, 0, 18),
        Position = UDim2.new(0, default and 24 or 2, 0.5, -9),
        BackgroundColor3 = Color3.fromRGB(255,255,255),
        BorderSizePixel = 0
    }, toggleBg)
    Create("UICorner", {CornerRadius = UDim.new(1, 0)}, toggleCircle)
    
    local btn = Create("TextButton", {Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = ""}, card)
    local active = default
    
    btn.MouseButton1Click:Connect(function()
        active = not active
        toggleBg.BackgroundColor3 = active and C.Accent or C.Sidebar
        toggleCircle:TweenPosition(UDim2.new(0, active and 24 or 2, 0.5, -9), "Out", "Quad", 0.2)
        if callback then callback(active) end
    end)
end

local function CreateSliderCard(title, desc, icon, parent, yPos, default, min, max, callback)
    local card = CreateCard(title, desc, icon, parent, yPos)
    
    local valLabel = Create("TextLabel", {
        Size = UDim2.new(0, 30, 0, 16),
        Position = UDim2.new(1, -90, 0.5, -8),
        BackgroundTransparency = 1,
        Text = tostring(default),
        TextColor3 = C.AccentLight,
        Font = Enum.Font.GothamBold,
        TextSize = 12
    }, card)
    
    local sliderBg = Create("Frame", {
        Size = UDim2.new(0, 100, 0, 6),
        Position = UDim2.new(1, -170, 0.5, -3),
        BackgroundColor3 = C.Sidebar,
        BorderSizePixel = 0
    }, card)
    Create("UICorner", {CornerRadius = UDim.new(1, 0)}, sliderBg)
    
    local sliderFill = Create("Frame", {
        Size = UDim2.new((default-min)/(max-min), 0, 1, 0),
        BackgroundColor3 = C.Accent,
        BorderSizePixel = 0
    }, sliderBg)
    Create("UICorner", {CornerRadius = UDim.new(1, 0)}, sliderFill)
    
    local dragging = false
    sliderBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end
    end)
    sliderBg.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local rel = math.clamp((input.Position.X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0, 1)
        sliderFill.Size = UDim2.new(rel, 0, 1, 0)
        local val = math.floor(min + (max - min) * rel)
        valLabel.Text = tostring(val)
        if callback then callback(val) end
    end
end)
end

