local HopBtn = CreateServerBtn("🔄 Server Hop", ServerPage)
HopBtn.MouseButton1Click:Connect(function()
    local id = game.PlaceId
    local servers = {}
    local success, data = pcall(function() return HttpService:GetAsync("https://games.roblox.com/v1/games/" .. id .. "/servers/Public?sortToken=&cursor=&maxItems=100&excludeFullGames=true") end)
    if success then
        local decoded = HttpService:JSONDecode(data)
        for _, s in ipairs(decoded.data) do
            if s.playing < s.maxPlayers and s.id ~= game.JobId then table.insert(servers, s.id) end
        end
        if #servers > 0 then TeleportService:TeleportToPlaceInstance(id, servers[math.random(1, #servers)], LocalPlayer) end
    end
end)

